apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-config
  namespace: {{ monitoring_namespace }}
  labels:
    app.kubernetes.io/part-of: platformforge
type: Opaque
stringData:
  alertmanager.yaml: |
    global:
      resolve_timeout: 5m
    route:
      receiver: "null"
      group_by: [alertname, namespace]
      group_wait: 30s
      group_interval: 5m
      repeat_interval: 4h
      routes:
        - receiver: "null"
          matchers:
            - alertname = "Watchdog"
{% if notification_provider | default('none') != 'none' %}
        - receiver: platform-alerts
          matchers:
            - severity = "critical"
          continue: true
{% endif %}
    receivers:
      - name: "null"
{% if notification_provider | default('none') == 'slack' %}
      - name: platform-alerts
        slack_configs:
          - api_url: "{{ slack_webhook_url }}"
            channel: "#{{ slack_channel }}-{{ env_name }}"
            title: '{% raw %}{{ .GroupLabels.alertname }}{% endraw %}'
            text: >-
              {% raw %}{{ range .Alerts }}
              *{{ .Labels.severity | toUpper }}* {{ .Labels.alertname }}
              Namespace: {{ .Labels.namespace }}
              {{ .Annotations.description }}
              {{ end }}{% endraw %}
            send_resolved: true
{% elif notification_provider | default('none') == 'email' %}
      - name: platform-alerts
        email_configs:
          - to: "{{ smtp_to }}"
            from: "{{ smtp_from }}"
            smarthost: "{{ smtp_host }}"
            auth_password: "{{ smtp_password }}"
            send_resolved: true
{% endif %}
    inhibit_rules:
      - source_matchers:
          - severity = "critical"
        target_matchers:
          - severity = "warning"
        equal: [alertname, namespace]
