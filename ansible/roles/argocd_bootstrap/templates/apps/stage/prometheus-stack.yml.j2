apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: prometheus-stack-stage
  namespace: argocd
  labels:
    app.kubernetes.io/part-of: platformforge
    platformforge/env: stage
    platformforge/service: prometheus-stack
  annotations:
    argocd.argoproj.io/sync-wave: "0"
    notifications.argoproj.io/subscribe.on-health-degraded: ""
    notifications.argoproj.io/subscribe.on-sync-failed: ""
spec:
  project: platform-stage

  sources:
    - repoURL: https://prometheus-community.github.io/helm-charts
      chart: kube-prometheus-stack
      targetRevision: "67.9.0"
      helm:
        valueFiles:
          - $values/platform/prometheus-stack/base-values.yaml
          - $values/platform/prometheus-stack/overlays/stage/values.yaml
        skipCrds: false

    - repoURL: {{ platformforge_repo_url }}
      targetRevision: {{ platformforge_repo_revision }}
      ref: values

  destination:
    server: https://kubernetes.default.svc
    namespace: {{ monitoring_stage_namespace }}

  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
      - RespectIgnoreDifferences=true
    retry:
      limit: 5
      backoff:
        duration: 30s
        factor: 2
        maxDuration: 5m

  ignoreDifferences:
    - group: admissionregistration.k8s.io
      kind: MutatingWebhookConfiguration
      jqPathExpressions:
        - .webhooks[]?.failurePolicy
    - group: admissionregistration.k8s.io
      kind: ValidatingWebhookConfiguration
      jqPathExpressions:
        - .webhooks[]?.failurePolicy
