apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: grafana
  labels:
    app.kubernetes.io/part-of: platformforge
spec:
  parentRefs:
    - name: traefik
      namespace: traefik
      sectionName: https
  hostnames:
    - {{ grafana_hostname }}
  rules:
    - backendRefs:
        - name: observability-{{ env_name }}-grafana
          port: 80
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: grafana-tls
spec:
  secretName: grafana-tls
  issuerRef:
    name: letsencrypt-prod
    kind: ClusterIssuer
  dnsNames:
    - {{ grafana_hostname }}
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: prometheus
  labels:
    app.kubernetes.io/part-of: platformforge
spec:
  parentRefs:
    - name: traefik
      namespace: traefik
      sectionName: https
  hostnames:
    - {{ prometheus_hostname }}
  rules:
    - backendRefs:
        - name: prometheus-operated
          port: 9090
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: prometheus-tls
spec:
  secretName: prometheus-tls
  issuerRef:
    name: letsencrypt-prod
    kind: ClusterIssuer
  dnsNames:
    - {{ prometheus_hostname }}
