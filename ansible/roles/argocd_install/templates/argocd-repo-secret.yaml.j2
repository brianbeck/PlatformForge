apiVersion: v1
kind: Secret
metadata:
  name: platformforge-env-repo
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
    app.kubernetes.io/part-of: platformforge
type: Opaque
stringData:
  type: git
  url: "{{ env_repo_url }}"
  username: "{{ github_pat_user | default('x-access-token') }}"
  password: "{{ github_pat }}"
