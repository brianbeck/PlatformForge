# Argo CD Helm values for {{ argocd_env }} environment
# Generated by PlatformForge bootstrap

global:
  logging:
    level: info
{% if ingress_enabled | default(false) | bool %}
{% if argocd_env == 'stage' %}
  domain: {{ argocd_hostname_stage }}
{% else %}
  domain: {{ argocd_hostname_prod }}
{% endif %}
{% endif %}

server:
  extraArgs:
{% if argocd_server_insecure %}
    - --insecure
{% endif %}
  service:
    type: ClusterIP

  # Ingress is handled via Traefik IngressRoute CRDs, not the chart's Ingress
  ingress:
    enabled: false

  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 256Mi

controller:
  resources:
    requests:
      cpu: 500m
      memory: 512Mi
    limits:
      cpu: "2"
      memory: 2Gi

  # Emit Kubernetes events on app health/sync changes
  metrics:
    enabled: true
    serviceMonitor:
      enabled: true
      labels:
        app.kubernetes.io/part-of: platformforge

repoServer:
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 256Mi

configs:
  params:
    # Reconciliation interval
    timeout.reconciliation: 60s
  cm:
    # Allow tracking by annotation
    application.resourceTrackingMethod: annotation

    # Argo CD Notifications triggers for Falco health monitoring
    # Argo CD evaluates Application health status continuously;
    # these notifications fire when Falco or Gatekeeper apps degrade.
    resource.customizations.health.argoproj.io_Application: |
      hs = {}
      if obj.status ~= nil then
        if obj.status.health ~= nil then
          hs.status = obj.status.health.status
          hs.message = obj.status.health.message
        end
      end
      return hs

  # RBAC: restrict default role to read-only
  rbac:
    policy.default: role:readonly
    policy.csv: |
      p, role:platform-admin, applications, *, platform-{{ argocd_env }}/*, allow
      p, role:platform-admin, projects, get, platform-{{ argocd_env }}, allow
      g, admin, role:platform-admin

  # Notifications configuration
  notifications:
    enabled: true
    # Templates for alert messages (Go template syntax escaped for Jinja2)
    templates:
      template.app-health-degraded: |
        message: |
          Application {{ '{{' }}.app.metadata.name{{ '}}' }} health is {{ '{{' }}.app.status.health.status{{ '}}' }}.
          Sync status: {{ '{{' }}.app.status.sync.status{{ '}}' }}
          {{ '{{' }}if .app.status.health.message{{ '}}' }}Message: {{ '{{' }}.app.status.health.message{{ '}}' }}{{ '{{' }}end{{ '}}' }}
      template.app-sync-failed: |
        message: |
          Application {{ '{{' }}.app.metadata.name{{ '}}' }} sync failed.
          {{ '{{' }}if .app.status.operationState{{ '}}' }}
          Error: {{ '{{' }}.app.status.operationState.message{{ '}}' }}
          {{ '{{' }}end{{ '}}' }}
      template.app-sync-succeeded: |
        message: |
          Application {{ '{{' }}.app.metadata.name{{ '}}' }} synced successfully.
          Revision: {{ '{{' }}.app.status.sync.revision{{ '}}' }}

    # Triggers define when notifications fire
    triggers:
      trigger.on-health-degraded: |
        - when: app.status.health.status == 'Degraded' || app.status.health.status == 'Missing'
          send: [app-health-degraded]
      trigger.on-sync-failed: |
        - when: app.status.operationState.phase in ['Error', 'Failed']
          send: [app-sync-failed]
      trigger.on-sync-succeeded: |
        - when: app.status.operationState.phase == 'Succeeded'
          send: [app-sync-succeeded]

    # Subscriptions: apply triggers to all apps by default
    subscriptions:
      - recipients:
{% if notification_provider | default('none') == 'slack' %}
          - "slack:{{ slack_channel }}"
{% elif notification_provider | default('none') == 'email' %}
          - "email:{{ smtp_to }}"
{% else %}
          []
{% endif %}
        triggers:
          - on-health-degraded
          - on-sync-failed

    # Service configuration
{% if notification_provider | default('none') == 'slack' %}
    services:
      service.slack: |
        apiURL: {{ slack_webhook_url }}
{% elif notification_provider | default('none') == 'email' %}
    services:
      service.email: |
        host: {{ smtp_host }}
        from: {{ smtp_from }}
        password: {{ smtp_password }}
{% endif %}
