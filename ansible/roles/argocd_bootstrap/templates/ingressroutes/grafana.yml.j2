apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: grafana
  namespace: {{ monitoring_namespace }}
  labels:
    app.kubernetes.io/part-of: platformforge
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`{{ grafana_hostname }}`)
      kind: Rule
      services:
        - name: observability-{{ env_suffix }}-grafana
          port: 80
          scheme: http
  tls: {}
