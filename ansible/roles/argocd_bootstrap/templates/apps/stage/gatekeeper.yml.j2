apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: gatekeeper-stage
  namespace: argocd
  labels:
    app.kubernetes.io/part-of: platformforge
    platformforge/env: stage
    platformforge/service: gatekeeper
  annotations:
    argocd.argoproj.io/sync-wave: "1"
    notifications.argoproj.io/subscribe.on-health-degraded: ""
    notifications.argoproj.io/subscribe.on-sync-failed: ""
spec:
  project: platform-stage

  sources:
    - repoURL: https://open-policy-agent.github.io/gatekeeper/charts
      chart: gatekeeper
      targetRevision: "3.22.0"
      helm:
        valueFiles:
          - $values/platform/gatekeeper/base-values.yaml
          - $values/platform/gatekeeper/overlays/stage/values.yaml

    - repoURL: {{ platformforge_repo_url }}
      targetRevision: {{ platformforge_repo_revision }}
      ref: values

    - repoURL: {{ platformforge_repo_url }}
      targetRevision: {{ platformforge_repo_revision }}
      path: platform/gatekeeper/constraints/templates

    - repoURL: {{ platformforge_repo_url }}
      targetRevision: {{ platformforge_repo_revision }}
      path: platform/gatekeeper/constraints/stage

  destination:
    server: https://kubernetes.default.svc
    namespace: {{ gatekeeper_stage_namespace }}

  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
      - RespectIgnoreDifferences=true
      - SkipDryRunOnMissingResource=true
    retry:
      limit: 3
      backoff:
        duration: 30s
        factor: 2
        maxDuration: 3m
