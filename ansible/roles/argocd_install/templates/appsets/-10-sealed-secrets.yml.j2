# Sealed Secrets Controller - Singleton (one per cluster)
# Wave -10: deploys before all other services so secrets are available
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: sealed-secrets
  namespace: argocd
spec:
  generators:
    - list:
        elements:
{% for entry in singleton_envs %}
          - env: "{{ entry.env }}"
            project: "{{ entry.project }}"
{% endfor %}
  template:
    metadata:
      name: "sealed-secrets-{{ '{{env}}' }}"
      namespace: argocd
      labels:
        app.kubernetes.io/part-of: platformforge
        platformforge/service: sealed-secrets
      annotations:
        argocd.argoproj.io/sync-wave: "-10"
        notifications.argoproj.io/subscribe.on-health-degraded: ""
        notifications.argoproj.io/subscribe.on-sync-failed: ""
    spec:
      project: "{{ '{{project}}' }}"
      sources:
        - repoURL: https://bitnami-labs.github.io/sealed-secrets
          chart: sealed-secrets
          targetRevision: "2.18.5"
          helm:
            valueFiles:
              - $values/platform/sealed-secrets/base-values.yaml
              - "$values/platform/sealed-secrets/overlays/{{ '{{env}}' }}/values.yaml"
        - repoURL: {{ platformforge_repo_url }}
          targetRevision: {{ platformforge_repo_revision }}
          ref: values
      destination:
        server: https://kubernetes.default.svc
        namespace: sealed-secrets
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        syncOptions:
          - CreateNamespace=true
          - ServerSideApply=true
        retry:
          limit: 5
          backoff:
            duration: 30s
            factor: 2
            maxDuration: 5m
