# Falco - Namespace-scoped (per environment)
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: falco
  namespace: argocd
spec:
  generators:
    - list:
        elements:
{% for entry in namespaced_envs %}
          - env: "{{ entry.env }}"
            namespace: "{{ entry.falco_namespace }}"
            project: "{{ entry.project }}"
{% endfor %}
  template:
    metadata:
      name: "falco-{{ '{{env}}' }}"
      namespace: argocd
      labels:
        app.kubernetes.io/part-of: platformforge
        platformforge/service: falco
      annotations:
        argocd.argoproj.io/sync-wave: "60"
        notifications.argoproj.io/subscribe.on-health-degraded: ""
        notifications.argoproj.io/subscribe.on-sync-failed: ""
    spec:
      project: "{{ '{{project}}' }}"
      sources:
        - repoURL: https://falcosecurity.github.io/charts
          chart: falco
          targetRevision: "8.0.1"
          helm:
            valueFiles:
              - $values/platform/falco/base-values.yaml
              - "$values/platform/falco/overlays/{{ '{{env}}' }}/values.yaml"
        - repoURL: {{ platformforge_repo_url }}
          targetRevision: {{ platformforge_repo_revision }}
          ref: values
        - repoURL: {{ platformforge_repo_url }}
          targetRevision: {{ platformforge_repo_revision }}
          path: platform/falco/rules
      destination:
        server: https://kubernetes.default.svc
        namespace: "{{ '{{namespace}}' }}"
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        syncOptions:
          - CreateNamespace=true
          - ServerSideApply=true
        retry:
          limit: 5
          backoff:
            duration: 30s
            factor: 2
            maxDuration: 5m
