apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-config
  namespace: {{ monitoring_namespace }}
  labels:
    app.kubernetes.io/part-of: platformforge
type: Opaque
stringData:
  alertmanager.yaml: |
    global:
      resolve_timeout: 5m
    route:
      receiver: "null"
      group_by: [alertname, namespace]
      group_wait: 30s
      group_interval: 5m
      repeat_interval: 4h
      routes:
        - receiver: "null"
          matchers:
            - alertname = "Watchdog"
        - receiver: "null"
          matchers:
            - alertname = "InfoInhibitor"
{% if notification_provider | default('none') == 'slack' %}
        # Security alerts (Falco) → #{{ slack_channel_security }}
        - receiver: security
          matchers:
            - alertname =~ "Falco.*"
          continue: true
        # Vulnerability alerts (Trivy) → #{{ slack_channel_vulnerabilities }}
        - receiver: vulnerabilities
          matchers:
            - alertname =~ ".*Vulnerability.*|TrivyOperator.*|.*Misconfiguration.*"
          continue: true
{% if env_name == 'stage' %}
        # Stage: all alerts → #{{ slack_channel_stage }}
        - receiver: stage-all
{% else %}
        # Prod critical → #{{ slack_channel_prod_critical }}
        - receiver: prod-critical
          matchers:
            - severity = "critical"
          continue: true
        # Prod warnings → #{{ slack_channel_prod_warnings }}
        - receiver: prod-warnings
          matchers:
            - severity = "warning"
{% endif %}
{% endif %}
    receivers:
      - name: "null"
{% if notification_provider | default('none') == 'slack' %}
      - name: security
        slack_configs:
          - api_url: "{{ slack_webhook_security }}"
            channel: "#{{ slack_channel_security }}"
            title: '{% raw %}{{ .GroupLabels.alertname }}{% endraw %}'
            text: >-
              {% raw %}{{ range .Alerts }}
              *{{ .Labels.severity | toUpper }}* {{ .Labels.alertname }}
              Namespace: {{ .Labels.namespace }}
              {{ .Annotations.description }}
              {{ end }}{% endraw %}
            send_resolved: true
      - name: vulnerabilities
        slack_configs:
          - api_url: "{{ slack_webhook_vulnerabilities }}"
            channel: "#{{ slack_channel_vulnerabilities }}"
            title: '{% raw %}{{ .GroupLabels.alertname }}{% endraw %}'
            text: >-
              {% raw %}{{ range .Alerts }}
              *{{ .Labels.severity | toUpper }}* {{ .Labels.alertname }}
              Namespace: {{ .Labels.namespace }}
              {{ .Annotations.description }}
              {{ end }}{% endraw %}
            send_resolved: true
{% if env_name == 'stage' %}
      - name: stage-all
        slack_configs:
          - api_url: "{{ slack_webhook_stage }}"
            channel: "#{{ slack_channel_stage }}"
            title: '{% raw %}{{ .GroupLabels.alertname }}{% endraw %}'
            text: >-
              {% raw %}{{ range .Alerts }}
              *{{ .Labels.severity | toUpper }}* {{ .Labels.alertname }}
              Namespace: {{ .Labels.namespace }}
              {{ .Annotations.description }}
              {{ end }}{% endraw %}
            send_resolved: true
{% else %}
      - name: prod-critical
        slack_configs:
          - api_url: "{{ slack_webhook_prod_critical }}"
            channel: "#{{ slack_channel_prod_critical }}"
            title: '{% raw %}{{ .GroupLabels.alertname }}{% endraw %}'
            text: >-
              {% raw %}{{ range .Alerts }}
              *{{ .Labels.severity | toUpper }}* {{ .Labels.alertname }}
              Namespace: {{ .Labels.namespace }}
              {{ .Annotations.description }}
              {{ end }}{% endraw %}
            send_resolved: true
      - name: prod-warnings
        slack_configs:
          - api_url: "{{ slack_webhook_prod_warnings }}"
            channel: "#{{ slack_channel_prod_warnings }}"
            title: '{% raw %}{{ .GroupLabels.alertname }}{% endraw %}'
            text: >-
              {% raw %}{{ range .Alerts }}
              *{{ .Labels.severity | toUpper }}* {{ .Labels.alertname }}
              Namespace: {{ .Labels.namespace }}
              {{ .Annotations.description }}
              {{ end }}{% endraw %}
            send_resolved: true
{% endif %}
{% elif notification_provider | default('none') == 'email' %}
      - name: platform-alerts
        email_configs:
          - to: "{{ smtp_to }}"
            from: "{{ smtp_from }}"
            smarthost: "{{ smtp_host }}"
            auth_password: "{{ smtp_password }}"
            send_resolved: true
{% endif %}
    inhibit_rules:
      - source_matchers:
          - severity = "critical"
        target_matchers:
          - severity = "warning"
        equal: [alertname, namespace]
