# cert-manager - Singleton (one per cluster)
# Wave 5: after secrets (-10), before Traefik (10)
# CRDs must exist before ClusterIssuers and Certificates can be created
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: cert-manager
  namespace: argocd
spec:
  generators:
    - list:
        elements:
{% for entry in singleton_envs %}
          - env: "{{ entry.env }}"
            project: "{{ entry.project }}"
{% endfor %}
  template:
    metadata:
      name: "cert-manager-{{ '{{env}}' }}"
      namespace: argocd
      labels:
        app.kubernetes.io/part-of: platformforge
        platformforge/service: cert-manager
      annotations:
        argocd.argoproj.io/sync-wave: "5"
        notifications.argoproj.io/subscribe.on-health-degraded: ""
        notifications.argoproj.io/subscribe.on-sync-failed: ""
    spec:
      project: "{{ '{{project}}' }}"
      sources:
        - repoURL: https://charts.jetstack.io
          chart: cert-manager
          targetRevision: "v1.20.2"
          helm:
            valueFiles:
              - $platform/platform/cert-manager/base-values.yaml
              - "$env/overlays/cert-manager/{{ '{{env}}' }}/values.yaml"
        - repoURL: {{ platformforge_repo_url }}
          targetRevision: {{ platformforge_repo_revision }}
          ref: platform
        - repoURL: {{ env_repo_url }}
          targetRevision: {{ env_repo_revision }}
          ref: env
        - repoURL: {{ env_repo_url }}
          targetRevision: {{ env_repo_revision }}
          path: "overlays/cert-manager/{{ '{{env}}' }}"
      destination:
        server: https://kubernetes.default.svc
        namespace: cert-manager
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        syncOptions:
          - CreateNamespace=true
          - ServerSideApply=true
          - SkipDryRunOnMissingResource=true
        retry:
          limit: 5
          backoff:
            duration: 30s
            factor: 2
            maxDuration: 5m
