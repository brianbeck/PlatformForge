# Alertmanager receiver configuration
# Generated by platformforge deploy — routes alerts to {{ notification_provider }}
alertmanager:
  config:
    receivers:
      - name: "null"
{% if notification_provider == 'slack' %}
      - name: critical
        slack_configs:
          - api_url: "{{ slack_webhook_url }}"
            channel: "#{{ slack_channel }}-{{ env_name }}"
            title: '{{ "{{" }} .GroupLabels.alertname {{ "}}" }}'
            text: >-
              {{ "{{" }} range .Alerts {{ "}}" }}
              *{{ "{{" }} .Labels.severity | toUpper {{ "}}" }}* {{ "{{" }} .Labels.alertname {{ "}}" }}
              Namespace: {{ "{{" }} .Labels.namespace {{ "}}" }}
              {{ "{{" }} .Annotations.description {{ "}}" }}
              {{ "{{" }} end {{ "}}" }}
            send_resolved: true
{% elif notification_provider == 'email' %}
      - name: critical
        email_configs:
          - to: "{{ smtp_to }}"
            from: "{{ smtp_from }}"
            smarthost: "{{ smtp_host }}"
            auth_password: "{{ smtp_password }}"
            send_resolved: true
{% else %}
      - name: critical
{% endif %}
