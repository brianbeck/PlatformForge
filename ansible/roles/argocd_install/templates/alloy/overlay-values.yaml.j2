# Alloy {{ env_name }} overlay — sets the Loki endpoint URL.
# Generated by platformforge deploy.
alloy:
  extraEnv:
    - name: LOKI_URL
      value: "{{ loki_url }}"
{% if env_name == 'stage' %}

resources:
  requests:
    cpu: 25m
    memory: 32Mi
  limits:
    cpu: 100m
    memory: 128Mi
{% else %}

resources:
  requests:
    cpu: 100m
    memory: 128Mi
  limits:
    cpu: 300m
    memory: 256Mi
{% endif %}
