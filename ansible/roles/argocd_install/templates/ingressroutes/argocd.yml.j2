apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: argocd-server
  namespace: argocd
  labels:
    app.kubernetes.io/part-of: platformforge
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`{{ argocd_hostname }}`)
      kind: Rule
      services:
        - name: argocd-server
          port: 80
          scheme: http
  tls: {}
