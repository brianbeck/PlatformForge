# Generated by PlatformForge bootstrap -- Ingress values for stage
{% if grafana_hostname_stage | default('') | length > 0 %}
grafana:
  ingress:
    enabled: true
    ingressClassName: traefik
    hosts:
      - {{ grafana_hostname_stage }}
    tls:
      - hosts:
          - {{ grafana_hostname_stage }}
        secretName: grafana-tls
{% endif %}

{% if prometheus_hostname_stage | default('') | length > 0 %}
prometheus:
  ingress:
    enabled: true
    ingressClassName: traefik
    hosts:
      - {{ prometheus_hostname_stage }}
    tls:
      - hosts:
          - {{ prometheus_hostname_stage }}
        secretName: prometheus-tls
{% endif %}
