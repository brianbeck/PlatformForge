# Gatekeeper ConstraintTemplates - Singleton (cluster-scoped)
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: gatekeeper-templates
  namespace: argocd
spec:
  generators:
    - list:
        elements:
{% for entry in singleton_envs %}
          - env: "{{ entry.env }}"
            project: "{{ entry.project }}"
{% endfor %}
  template:
    metadata:
      name: "gatekeeper-templates-{{ '{{env}}' }}"
      namespace: argocd
      labels:
        app.kubernetes.io/part-of: platformforge
        platformforge/service: gatekeeper
      annotations:
        argocd.argoproj.io/sync-wave: "40"
        notifications.argoproj.io/subscribe.on-sync-failed: ""
    spec:
      project: "{{ '{{project}}' }}"
      sources:
        - repoURL: {{ platformforge_repo_url }}
          targetRevision: {{ platformforge_repo_revision }}
          path: platform/gatekeeper/templates
      destination:
        server: https://kubernetes.default.svc
        namespace: gatekeeper-system
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        syncOptions:
          - ServerSideApply=true
          - SkipDryRunOnMissingResource=true
        retry:
          limit: 5
          backoff:
            duration: 30s
            factor: 2
            maxDuration: 5m
