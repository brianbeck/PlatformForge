# Generated by PlatformForge bootstrap -- Ingress values for prod
{% if grafana_hostname_prod | default('') | length > 0 %}
grafana:
  ingress:
    enabled: true
    ingressClassName: traefik
    hosts:
      - {{ grafana_hostname_prod }}
    tls:
      - hosts:
          - {{ grafana_hostname_prod }}
        secretName: grafana-tls
{% endif %}

{% if prometheus_hostname_prod | default('') | length > 0 %}
prometheus:
  ingress:
    enabled: true
    ingressClassName: traefik
    hosts:
      - {{ prometheus_hostname_prod }}
    tls:
      - hosts:
          - {{ prometheus_hostname_prod }}
        secretName: prometheus-tls
{% endif %}
