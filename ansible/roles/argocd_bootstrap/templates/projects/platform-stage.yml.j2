apiVersion: argoproj.io/v1alpha1
kind: AppProject
metadata:
  name: platform-stage
  namespace: argocd
spec:
  description: PlatformForge stage environment platform services

  sourceRepos:
    - "{{ platformforge_repo_url }}"
    - "https://falcosecurity.github.io/charts"
    - "https://open-policy-agent.github.io/gatekeeper/charts"
    - "https://prometheus-community.github.io/helm-charts"
    - "https://traefik.github.io/charts"
    - "https://aquasecurity.github.io/helm-charts/"

  destinations:
    - server: "https://kubernetes.default.svc"
      namespace: "{{ falco_stage_namespace }}"
    - server: "https://kubernetes.default.svc"
      namespace: "trivy-system"
    - server: "https://kubernetes.default.svc"
      namespace: "{{ gatekeeper_stage_namespace }}"
    - server: "https://kubernetes.default.svc"
      namespace: "{{ monitoring_stage_namespace }}"
    - server: "https://kubernetes.default.svc"
      namespace: "kube-system"
    - server: "https://kubernetes.default.svc"
      namespace: "traefik"

  clusterResourceWhitelist:
    - group: ""
      kind: Namespace
    - group: rbac.authorization.k8s.io
      kind: ClusterRole
    - group: rbac.authorization.k8s.io
      kind: ClusterRoleBinding
    - group: templates.gatekeeper.sh
      kind: ConstraintTemplate
    - group: constraints.gatekeeper.sh
      kind: "*"
    - group: admissionregistration.k8s.io
      kind: ValidatingWebhookConfiguration
    - group: admissionregistration.k8s.io
      kind: MutatingWebhookConfiguration
    - group: monitoring.coreos.com
      kind: PrometheusRule
    - group: apiextensions.k8s.io
      kind: CustomResourceDefinition
    - group: networking.k8s.io
      kind: IngressClass
    - group: traefik.io
      kind: "*"

  namespaceResourceWhitelist:
    - group: ""
      kind: ConfigMap
    - group: ""
      kind: Secret
    - group: ""
      kind: Service
    - group: ""
      kind: ServiceAccount
    - group: apps
      kind: DaemonSet
    - group: apps
      kind: Deployment
    - group: apps
      kind: StatefulSet
    - group: apps
      kind: ReplicaSet
    - group: ""
      kind: PersistentVolumeClaim
    - group: ""
      kind: Endpoints
    - group: rbac.authorization.k8s.io
      kind: Role
    - group: rbac.authorization.k8s.io
      kind: RoleBinding
    - group: networking.k8s.io
      kind: NetworkPolicy
    - group: monitoring.coreos.com
      kind: ServiceMonitor
    - group: monitoring.coreos.com
      kind: PrometheusRule
    - group: monitoring.coreos.com
      kind: Prometheus
    - group: monitoring.coreos.com
      kind: Alertmanager
    - group: ""
      kind: Pod
    - group: batch
      kind: Job
    - group: ""
      kind: ResourceQuota
    - group: networking.k8s.io
      kind: Ingress
    - group: traefik.io
      kind: IngressRoute
    - group: traefik.io
      kind: Middleware
    - group: policy
      kind: PodDisruptionBudget

  orphanedResources:
    warn: true
