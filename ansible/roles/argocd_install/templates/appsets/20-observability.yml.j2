# Observability Stack - Namespace-scoped (per environment)
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: observability
  namespace: argocd
spec:
  generators:
    - list:
        elements:
{% for entry in namespaced_envs %}
          - env: "{{ entry.env }}"
            namespace: "{{ entry.monitoring_namespace }}"
            project: "{{ entry.project }}"
{% endfor %}
  template:
    metadata:
      name: "observability-{{ '{{env}}' }}"
      namespace: argocd
      labels:
        app.kubernetes.io/part-of: platformforge
        platformforge/service: observability
      annotations:
        argocd.argoproj.io/sync-wave: "20"
        notifications.argoproj.io/subscribe.on-health-degraded: ""
        notifications.argoproj.io/subscribe.on-sync-failed: ""
    spec:
      project: "{{ '{{project}}' }}"
      sources:
        - repoURL: https://prometheus-community.github.io/helm-charts
          chart: kube-prometheus-stack
          targetRevision: "82.15.1"
          helm:
            valueFiles:
              - $values/platform/observability/base-values.yaml
              - "$values/platform/observability/overlays/{{ '{{env}}' }}/values.yaml"
              - $values/platform/observability/dashboards/dashboards-values.yaml
            skipCrds: false
        - repoURL: {{ platformforge_repo_url }}
          targetRevision: {{ platformforge_repo_revision }}
          ref: values
        - repoURL: {{ platformforge_repo_url }}
          targetRevision: {{ platformforge_repo_revision }}
          path: "platform/observability/overlays/{{ '{{env}}' }}"
      destination:
        server: https://kubernetes.default.svc
        namespace: "{{ '{{namespace}}' }}"
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        syncOptions:
          - CreateNamespace=true
          - ServerSideApply=true
          - RespectIgnoreDifferences=true
        retry:
          limit: 5
          backoff:
            duration: 30s
            factor: 2
            maxDuration: 5m
      ignoreDifferences:
        - group: gateway.networking.k8s.io
          kind: HTTPRoute
          jqPathExpressions:
            - .spec.parentRefs
            - .spec.rules
        - group: admissionregistration.k8s.io
          kind: MutatingWebhookConfiguration
          jqPathExpressions:
            - .webhooks[]?.failurePolicy
            - .webhooks[]?.clientConfig.caBundle
        - group: admissionregistration.k8s.io
          kind: ValidatingWebhookConfiguration
          jqPathExpressions:
            - .webhooks[]?.failurePolicy
            - .webhooks[]?.clientConfig.caBundle
        # Grafana secret contains auto-generated admin password
        - group: ""
          kind: Secret
          name: "observability-{{ '{{env}}' }}-grafana"
          jqPathExpressions:
            - .data
        # Grafana deployment checksum annotation changes with secret
        - group: apps
          kind: Deployment
          name: "observability-{{ '{{env}}' }}-grafana"
          jqPathExpressions:
            - .spec.template.metadata.annotations
