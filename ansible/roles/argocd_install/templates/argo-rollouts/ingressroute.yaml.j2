# Argo Rollouts dashboard exposure via Traefik.
# Generated by Ansible into platform/argo-rollouts/overlays/<env>/ingressroute.yaml
# and reconciled by the argo-rollouts-rbac ApplicationSet directory source.
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: argo-rollouts-dashboard
  namespace: argo-rollouts
  labels:
    app.kubernetes.io/part-of: platformforge
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`{{ rollouts_hostname }}`)
      kind: Rule
      services:
        - name: argo-rollouts-dashboard
          port: 3100
          scheme: http
  tls:
    secretName: argo-rollouts-tls
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: argo-rollouts-tls
  namespace: argo-rollouts
spec:
  secretName: argo-rollouts-tls
  issuerRef:
    name: letsencrypt-prod
    kind: ClusterIssuer
  dnsNames:
    - {{ rollouts_hostname }}
